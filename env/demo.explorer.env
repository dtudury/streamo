# Demo explorer author. Watches public/apps/explorer/ on disk and syncs
# to the relay. Once running, the homepage's "explorer" link resolves
# (via the apps/explorer/ mount) and the full explorer app loads —
# including the commit-wheel work shipped this morning.
STREAMO_NAME=demo-explorer
STREAMO_USERNAME=demo
STREAMO_PASSWORD=demo
STREAMO_KEY_ITERATIONS=1
STREAMO_DATA_DIR=.streamo-demo-explorer
STREAMO_FILES=public/apps/explorer
STREAMO_ORIGIN=localhost:8081
STREAMO_VERBOSE=trace
