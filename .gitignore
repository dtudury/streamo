# Dependency directories
node_modules/

# turtleDB uses this file and should ignore git stuff
.git/

# git uses this file and should ignore turtleDB stuff
.turtleDB/

# streamo archive data (also excluded from fileSync via buildFilter).
# .streamo-* catches the demo:relay / demo:homepage / demo:library /
# demo:explorer data dirs (and any other local data dirs that follow
# the .streamo-NAME convention).
.streamo/
.stream/
.streamo-*/

# Optional REPL history
.node_repl_history

# dotenv environment variable files — env/ holds them as of 2026-05-28.
# Convention: anything in env/secrets/ is private (gitignored); everything
# else in env/ is fair game to commit. Structure declares policy — no
# negation pattern needed; you can't accidentally leak a secret by
# mistyping a name. env/dev.env and env/demo.*.env are tracked examples
# (demo uses demo/demo with 1 PBKDF2 iteration — toy credentials).
.env
.env.*
env/secrets/

# the true price of a pretty laptop
**/.DS_Store