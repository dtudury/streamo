{
  "name": "@dtudury/streamo",
  "version": "14.1.0",
  "description": "peer-to-peer sync where your data and identity belong to you, not the server",
  "keywords": [
    "p2p",
    "peer-to-peer",
    "sync",
    "reactive",
    "content-addressed",
    "websocket",
    "signed",
    "append-only",
    "offline-first",
    "cryptographic",
    "identity"
  ],
  "homepage": "https://streamo.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dtudury/streamo.git"
  },
  "bugs": {
    "url": "https://github.com/dtudury/streamo/issues"
  },
  "author": "David Tudury <david.tudury@gmail.com>",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./*": "./public/streamo/*"
  },
  "files": [
    "index.js",
    "bin/",
    "public/",
    "!**/*.test.js",
    "!public/streamo/utils/testing.js",
    "!public/streamo/utils/mockDOM.js"
  ],
  "bin": "./bin/streamo.js",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-s3": "^3.958.0",
    "@gerhobbelt/gitignore-parser": "^0.2.0-9",
    "@parcel/watcher": "^2.5.1",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mkcert": "^3.2.0",
    "readline-sync": "^1.4.10",
    "ws": "^8.18.3"
  },
  "scripts": {
    "test": "node --test",
    "typecheck": "tsc -p jsconfig.json",
    "dev": "STREAMO_LOG_LEVEL=trace node public/apps/chat/server.js --env-file env/dev.env",
    "prod": "node public/apps/chat/server.js --env-file env/prod.env",
    "demo:relay": "node bin/streamo.js --env-file env/demo.relay.env",
    "demo:homepage": "node bin/streamo.js --env-file env/demo.homepage.env",
    "demo:library": "node bin/streamo.js --env-file env/demo.library.env",
    "demo:explorer": "node bin/streamo.js --env-file env/demo.explorer.env",
    "david": "node bin/streamo.js --config env/david-home.json",
    "seed-history": "node scripts/seed-history.js",
    "fork-homepage": "node scripts/fork-homepage.js",
    "deploy": "bash scripts/deploy.sh",
    "streamo:as": "node scripts/streamo-as.mjs",
    "streamo:as:lib": "node scripts/streamo-as.mjs streamo-library",
    "streamo:as:claude": "node scripts/streamo-as.mjs claude"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
