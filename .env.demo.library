# Demo library author. Watches public/streamo/ on disk (the actual streamo
# JS library — h.js, mount.js, Signer.js, etc.) and syncs to the relay.
# Once running, the homepage's /streamo/*.js imports resolve via the
# library mount instead of 404ing.
STREAMO_NAME=demo-library
STREAMO_USERNAME=demo
STREAMO_PASSWORD=demo
STREAMO_KEY_ITERATIONS=1
STREAMO_DATA_DIR=.streamo-demo-library
STREAMO_FILES=public/streamo
STREAMO_ORIGIN=localhost:8081
STREAMO_VERBOSE=trace
