# Dependency directories
node_modules/

# turtleDB uses this file and should ignore git stuff
.git/

# git uses this file and should ignore turtleDB stuff
.turtleDB/

# streamo archive data (also excluded from fileSync via buildFilter)
.streamo/
.stream/
.streamo-*/   # demo:relay, demo:homepage, demo:library, demo:explorer dirs and similar local data dirs

# Optional REPL history
.node_repl_history

# dotenv environment variable files — everything except .env.dev and
# .env.demo.*, which are tracked as examples (demo uses demo/demo with
# 1 PBKDF2 iteration — toy credentials, fine to commit). .env.prod lives
# on the server; .env.claude lives only on author machines and holds a
# signing password.
.env
.env.*
!.env.dev
!.env.demo.*

# the true price of a pretty laptop
**/.DS_Store