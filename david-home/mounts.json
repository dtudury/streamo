      "ours": true
    },
    "turnstone/": {
      "key": "TODO-claude-turnstone-record-pubkey",
      "ours": false
    },
    "watcher/": {
      "key": "TODO-wake-watcher-record-pubkey",
      "ours": false
    }
  }
