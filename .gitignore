# Dependency directories
node_modules/

# turtleDB uses this file and should ignore git stuff
.git/

# git uses this file and should ignore turtleDB stuff
.turtleDB/

# streamo archive data (also excluded from fileSync via buildFilter)
.streamo/
.stream/

# Optional REPL history
.node_repl_history

# dotenv environment variable files — everything except .env.dev,
# which is tracked as an example. .env.prod lives on the server;
# .env.claude lives only on author machines and holds a signing
# password.
.env
.env.*
!.env.dev

# the true price of a pretty laptop
**/.DS_Store

# three-record demo scaffolding — built by scripts/demo-three-records.js
demo/